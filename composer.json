{
    "name": "bvp/notifier",
    "description": "BVP Notifier",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "boatrace",
        "library"
    ],
    "authors": [
        {
            "name": "shimomo",
            "email": "bvp@shimomo.net"
        }
    ],
    "support": {
        "issues": "https://github.com/boatracevibeproject/notifier/issues",
        "source": "https://github.com/boatracevibeproject/notifier"
    },
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.12.1",
        "nesbot/carbon": "^3.8.4",
        "vlucas/phpdotenv": "^5.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.52",
        "phpunit/phpunit": "^13.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "BVP\\Notifier\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BVP\\Notifier\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        }
    },
    "$schema": "https://getcomposer.org/schema.json"
}
